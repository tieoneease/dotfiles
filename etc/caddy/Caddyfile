# Local Portless router
# Maps *.<vps>.localhost → SSH-forwarded Portless ports
# Access remote dev servers with clean URLs (no port to remember):
#   http://booking-agent.pydantic-agent.sambot.localhost
#   http://myapp.sambot.localhost
#
# Uses regex host matching to support any number of subdomain levels
# (Portless URLs are <name>.<project>.localhost:1355).
#
# Each SSH host forwards its remote Portless (port 1355) to a unique local port.
# Caddy rewrites the Host header so the remote Portless routes correctly.
#
# To add a new VPS:
#   1. Add SSH host with LocalForward <port> localhost:1355
#   2. Add a @name matcher and handle block below
#   3. Run: sudo cp etc/caddy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy

:80 {
	@sambot header_regexp samhost Host ^(.+)\.sambot\.localhost(?::\d+)?$
	handle @sambot {
		reverse_proxy localhost:1357 {
			header_up Host {re.samhost.1}.localhost:1355
		}
	}

	@peachy header_regexp peachyhost Host ^(.+)\.peachy-data\.localhost(?::\d+)?$
	handle @peachy {
		reverse_proxy localhost:1356 {
			header_up Host {re.peachyhost.1}.localhost:1356
		}
	}
}
