#!/usr/bin/env bash

# md-browser — Render markdown (with mermaid diagrams) or standalone mermaid files in Chrome
# Used as a yazi opener for rich previewing of .md, .mmd, and .mermaid files.
# Dependencies: google-chrome-stable (or chromium), base64

set -euo pipefail

if [ $# -eq 0 ]; then
    echo "Usage: md-browser <file.md|file.mmd|file.mermaid>"
    exit 1
fi

FILE="$1"
EXT="${FILE##*.}"
FILENAME="$(basename "$FILE")"
CACHE_DIR="$HOME/.cache/md-preview"
mkdir -p "$CACHE_DIR"
OUTFILE="$CACHE_DIR/preview.html"

# Base64-encode file content to avoid HTML escaping issues
CONTENT_B64=$(base64 -w0 "$FILE")

if [[ "$EXT" == "mmd" || "$EXT" == "mermaid" ]]; then
    # Standalone mermaid file — render diagram only
    cat > "$OUTFILE" << HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>${FILENAME} — Mermaid Preview</title>
    <style>
        body {
            background: #0d1117; color: #c9d1d9;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; margin: 0; padding: 20px;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
        }
        .mermaid svg { max-width: 100%; height: auto; }
    </style>
    <script type="module">
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
        mermaid.initialize({ startOnLoad: false, theme: 'dark' });
        const raw = atob('${CONTENT_B64}');
        const el = document.getElementById('diagram');
        const { svg } = await mermaid.render('d', raw);
        el.innerHTML = svg;
    </script>
</head>
<body>
    <div id="diagram"></div>
</body>
</html>
HTMLEOF
else
    # Markdown file — render with marked + mermaid + highlight.js
    cat > "$OUTFILE" << HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>${FILENAME}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css@5/github-markdown-dark.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11/styles/github-dark.min.css">
    <style>
        body {
            background: #0d1117; color: #c9d1d9;
            max-width: 980px; margin: 0 auto; padding: 40px 20px;
        }
        .markdown-body { background: transparent; }
        .mermaid { background: transparent; text-align: center; margin: 16px 0; }
        .mermaid svg { max-width: 100%; height: auto; }
    </style>
</head>
<body class="markdown-body">
    <div id="content"></div>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11/highlight.min.js"></script>
    <script type="module">
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
        mermaid.initialize({ startOnLoad: false, theme: 'dark' });

        // Render markdown normally
        marked.setOptions({ gfm: true, breaks: false });
        const raw = atob('${CONTENT_B64}');
        document.getElementById('content').innerHTML = marked.parse(raw);

        // Syntax highlight code blocks
        document.querySelectorAll('pre code[class*="language-"]').forEach(el => {
            hljs.highlightElement(el);
        });

        // Post-process: convert mermaid code blocks to rendered diagrams
        const mermaidBlocks = document.querySelectorAll('code.language-mermaid');
        for (let i = 0; i < mermaidBlocks.length; i++) {
            const code = mermaidBlocks[i].textContent;
            const pre = mermaidBlocks[i].closest('pre');
            const div = document.createElement('div');
            div.className = 'mermaid';
            try {
                const { svg } = await mermaid.render('m' + i, code);
                div.innerHTML = svg;
            } catch (e) {
                div.textContent = 'Mermaid error: ' + e.message;
            }
            pre.replaceWith(div);
        }
    </script>
</body>
</html>
HTMLEOF
fi

# Open in Chrome
if command -v google-chrome-stable &>/dev/null; then
    google-chrome-stable "file://$OUTFILE" &
elif command -v chromium &>/dev/null; then
    chromium "file://$OUTFILE" &
elif command -v xdg-open &>/dev/null; then
    xdg-open "file://$OUTFILE" &
else
    echo "Error: No browser found"
    exit 1
fi
