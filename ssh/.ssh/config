Host *
    # Reuse SSH connections — scp/sftp piggyback on existing sessions.
    # Critical for ssh-image-paste (no extra auth round-trip).
    ControlMaster auto
    ControlPath /tmp/ssh_mux_%r@%h-%p
    ControlPersist 600
    ServerAliveInterval 60

Host sambot
    HostName sambot-vm
    User sam
    # Forward Portless — all dev servers accessible as <name>.localhost:1355
    LocalForward 1355 localhost:1355

Host peachy-data
    HostName peachy-data
    User sam
    # Forward Portless — dev servers accessible as <name>.localhost:1356
    LocalForward 1356 localhost:1355
