Host *
    # Reuse SSH connections — scp/sftp piggyback on existing sessions.
    # Critical for ssh-image-paste (no extra auth round-trip).
    ControlMaster auto
    ControlPath /tmp/ssh_mux_%r@%h-%p
    ControlPersist 600
    ServerAliveInterval 60

Host sambot
    HostName sambot-vm
    User sam

Host peachy-data
    HostName peachy-data
    User sam
